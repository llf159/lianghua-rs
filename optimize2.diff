+    if trimmed.is_empty() {
+        return Err("数据目录为空，请先到数据管理页确认当前目录".to_string());
+    }
+
+    let path = ind_toml_path(trimmed);
+    let text = build_indicator_manage_toml(&items)?;
+    fs::write(&path, text)
+        .map_err(|e| format!("写入指标配置失败: path={}, err={e}", path.display()))?;
+    get_indicator_manage_page(trimmed)
+}
