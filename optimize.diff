+        } else {
+            return Ok(Vec::new());
+        }
+    } else {
+        None
+    };
+
+    let industry_map: Option<&HashMap<String, f64>> = if use_industry {
+        if input.industry.trim().is_empty() {
+            Some(index_series)
+        } else if let Some(series) = factor_series.industry_series {
+            if series.is_empty() {
+                return Ok(Vec::new());
