{
  "$schema": "../gen/schemas/android-schema.json",
  "identifier": "android-db-import",
  "description": "allow db import on android",
  "windows": ["main"],
  "permissions": [
    "dialog:default",
    "fs:default",
    "fs:allow-copy-file",
    "fs:allow-read-dir",
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write-recursive"
  ],
  "platforms": ["android"]
}
